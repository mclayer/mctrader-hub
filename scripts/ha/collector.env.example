# Per-host collector configuration (loaded by EnvironmentFile in systemd unit)
# Copy to /etc/mctrader/collector.env on each node and edit per-host values.

# Node identifier — MUST be unique across active-active cluster.
# Conventionally `NODE_A`, `NODE_B`, `NODE_C`. Drives `node=` partition split
# and `heartbeat-{NODE_ID}.json` file name.
NODE_ID=NODE_A

# Shared data root — MUST mount the same NFS/SMB/Ceph share at the same path
# on all nodes with same uid:gid for atomic-rename POSIX semantics.
MCTRADER_DATA_ROOT=/mnt/shared/mctrader/data

# Optional: heartbeat write interval override (default 5.0)
# HEARTBEAT_INTERVAL=5.0

# Optional: log level override (default INFO)
# LOG_LEVEL=INFO
