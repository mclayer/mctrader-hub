# mctrader cold tier MinIO — .env template
# Copy this file to .env on NAS Container Manager, then fill actual values.
# IMPORTANT: .env is .gitignored — do NOT commit credentials.

# MinIO root credentials (rotate every 90 days — see docs/runbooks/nas-minio-secret-rotation.md)
MINIO_ROOT_USER=mctrader-admin
MINIO_ROOT_PASSWORD=CHANGE_ME_TO_RANDOM_32_CHAR_STRING

# NAS host IP or DNS name (used by MinIO Console redirect URL)
# Example: 192.168.1.100 or nas.lan
NAS_HOST=CHANGE_ME_TO_NAS_IP_OR_HOSTNAME
