# mctrader-hub/.env.prod.example — prod profile template
# Copy to .env.prod and fill actual values (rotation 90d, see docs/runbooks/nas-minio-secret-rotation.md)
# Usage: docker compose --profile prod --env-file .env.prod up
# ADR-030 §D3: prod profile = NAS MinIO (endpoint=http://mcnas01.internal.mclayer.it:9000)
# Docker Compose profile (ADR-030 §D3) — `docker compose --profile prod` flag 시 자동 set
# 단일 profile 운영 의무 (multi-profile dev,prod 동시 set 금지, runbook §Single Profile)
COMPOSE_PROFILES=prod
POSTGRES_PASSWORD=<rotate>
MINIO_ACCESS_KEY=<not_used_in_prod>
MINIO_SECRET_KEY=<not_used_in_prod>
GRAFANA_ADMIN_PASSWORD=<rotate>
ECOS_API_KEY=<from_ecos_portal>
COINGLASS_API_KEY=<from_coinglass_portal>
# NAS MinIO endpoint (prod = NAS Synology)
NAS_MINIO_ENDPOINT=http://mcnas01.internal.mclayer.it:9000
NAS_MINIO_ACCESS_KEY=<from_nas_minio_console>
NAS_MINIO_SECRET_KEY=<from_nas_minio_console>
NAS_MINIO_BUCKET=mctrader-market

# paper-engine universe (D10, MCT-177)
UNIVERSE_TOP_N=50

# Redis key prefix (D15, MCT-177) — signal:/market:/engine: 3 namespace
REDIS_KEY_PREFIX_ENGINE=engine
REDIS_KEY_PREFIX_MARKET=market
REDIS_KEY_PREFIX_SIGNAL=signal
