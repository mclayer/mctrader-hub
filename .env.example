# Docker Compose profile (ADR-030 §D3) — `docker compose --profile dev` flag 시 자동 set
# 단일 profile 운영 의무 (multi-profile dev,prod 동시 set 금지, runbook §Single Profile)
COMPOSE_PROFILES=dev

# MCT-181 D12: image registry pin — dev=latest (CI push 최신 image)
# prod: IMAGE_TAG=sha-<7char> 또는 vX.Y.Z release pin (see .env.prod.example)
IMAGE_TAG=latest

POSTGRES_PASSWORD=changeme
MINIO_ACCESS_KEY=mctrader
MINIO_SECRET_KEY=changeme_minio
GRAFANA_ADMIN_PASSWORD=changeme_grafana

# signal-collector
ECOS_API_KEY=
COINGLASS_API_KEY=

# NAS MinIO (prod profile only — dev 은 hub MinIO 폴백)
NAS_MINIO_ENDPOINT=http://mcnas01.internal.mclayer.it:9000
NAS_MINIO_ACCESS_KEY=changeme_nas
NAS_MINIO_SECRET_KEY=changeme_nas_secret
NAS_MINIO_BUCKET=mctrader-market

# paper-engine universe (D10, MCT-177)
UNIVERSE_TOP_N=50

# Redis key prefix (D15, MCT-177) — signal:/market:/engine: 3 namespace
REDIS_KEY_PREFIX_ENGINE=engine
REDIS_KEY_PREFIX_MARKET=market
REDIS_KEY_PREFIX_SIGNAL=signal
